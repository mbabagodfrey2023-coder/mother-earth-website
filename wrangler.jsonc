{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mother-earth-website",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-26",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "COUNCIL_ARCHIVE",
      "id": "ed72059a838b4b8f8ccde26eb6122a85"
    }
  ]
}
