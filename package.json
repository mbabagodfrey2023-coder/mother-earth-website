{
  "name": "mother-earth-website",
  "private": true,
  "scripts": {
    "predeploy": "node scripts/check-syntax.js",
    "deploy":  "npx wrangler deploy --name mother-earth-website",
    "dev":     "npx wrangler dev --name mother-earth-website",
    "secret":  "npx wrangler secret put --name mother-earth-website",
    "secrets": "echo 'Usage: npm run secret <SECRET_NAME>\\nExample: npm run secret X_API_KEY'",
    "kv":      "npx wrangler kv --name mother-earth-website",
    "tail":    "npx wrangler tail --name mother-earth-website"
  },
  "devDependencies": {
    "docx": "^9.7.1",
    "wrangler": "4.86.0"
  }
}
