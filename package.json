{
  "name": "mother-earth-website",
  "private": true,
  "scripts": {
    "deploy":  "wrangler deploy --name mother-earth-website",
    "dev":     "wrangler dev --name mother-earth-website",
    "secret":  "wrangler secret put --name mother-earth-website",
    "secrets": "echo 'Usage: npm run secret <SECRET_NAME>\\nExample: npm run secret X_API_KEY'",
    "kv":      "wrangler kv --name mother-earth-website",
    "tail":    "wrangler tail --name mother-earth-website"
  },
  "devDependencies": {
    "docx": "^9.7.1",
    "wrangler": "^4.86.0"
  }
}
